{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project (MSYS2 UCRT64)",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-std=c++26",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/cv/conv.cpp",
                "-o",
                "${workspaceFolder}/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
